        {
          "name": "Login — POST /api/auth/login/ ✦ guarda tokens",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "",
                  "if (json.access) {",
                  "  pm.collectionVariables.set('accessToken', json.access);",
                  "  pm.environment.set('accessToken', json.access);",
                  "}",
                  "if (json.refresh) {",
                  "  pm.collectionVariables.set('refreshToken', json.refresh);",
                  "  pm.environment.set('refreshToken', json.refresh);",
                  "}",
                  "",
                  "pm.test('Login exitoso — tokens recibidos', () => {",
                  "  pm.expect(json.access).to.be.a('string');",
                  "  pm.expect(json.refresh).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
